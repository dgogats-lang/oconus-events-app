// This is your Prisma schema file.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  directUrl = env("DATABASE_URL")
  url       = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Auth.js (NextAuth v5) required tables
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(STAFF)

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

enum Role {
  ADMIN
  STAFF
}

// ─────────────────────────────────────────────
// Core domain models
// ─────────────────────────────────────────────

// Top-level organizing unit (e.g., "HOH Europe Summits 2026")
// Added by this app — Quickbase uses a separate template app per trip instead.
model Trip {
  id          String   @id @default(cuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)

  events    Event[]
  attendees Attendee[]
  hotels    Hotel[]    // transit hotels not tied to a specific event

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A specific summit/stop within a Trip (e.g., "Munich Summit")
model Event {
  id       String   @id @default(cuid())
  tripId   String
  name     String
  city     String
  country  String
  date     DateTime
  timezone String   @default("UTC")

  trip               Trip                @relation(fields: [tripId], references: [id], onDelete: Cascade)
  eventRegistrations EventRegistration[]
  hotels             Hotel[]
  movements          Movement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Company / organization associated with attendees
model Company {
  id   String @id @default(cuid())
  name String @unique

  attendees Attendee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A person whose travel is managed for a Trip
model Attendee {
  id            String  @id @default(cuid())
  tripId        String
  companyId     String?
  firstName     String
  lastName      String
  email         String
  phone         String?
  hasDodId      Boolean @default(false)
  travelPackage Boolean @default(false)
  notes         String?

  // Personal arrival flight (trip-level — one per attendee)
  arrivalAirline      String?
  arrivalFlightNumber String?
  arrivalAirport      String?
  arrivalScheduledAt  DateTime?
  arrivalActualAt     DateTime?
  arrivalStatus       FlightStatus @default(SCHEDULED)

  // Personal departure flight (trip-level — one per attendee)
  departureAirline      String?
  departureFlightNumber String?
  departureAirport      String?
  departureScheduledAt  DateTime?
  departureActualAt     DateTime?
  departureStatus       FlightStatus @default(SCHEDULED)

  trip                    Trip                    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  company                 Company?                @relation(fields: [companyId], references: [id])
  eventRegistrations      EventRegistration[]
  hotelManifestEntries    HotelManifestEntry[]
  movementManifestEntries MovementManifestEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
  @@index([lastName])
}

// Explicit registration of an Attendee at an Event (mirrors Quickbase Event Registrations)
model EventRegistration {
  id         String @id @default(cuid())
  attendeeId String
  eventId    String

  attendee Attendee @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([attendeeId, eventId])
  @@index([attendeeId])
  @@index([eventId])
}

// A hotel for an Event stop or a transit stop between events.
// Exactly one of eventId or tripId must be set.
model Hotel {
  id      String  @id @default(cuid())
  eventId String? // null for transit hotels
  tripId  String? // set for transit hotels; also set for event hotels (denormalized for easy querying)
  name    String
  address String?
  phone   String?
  notes   String?

  event                Event?               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  trip                 Trip?                @relation(fields: [tripId], references: [id], onDelete: Cascade)
  hotelManifestEntries HotelManifestEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
  @@index([tripId])
}

// Links an Attendee to a Hotel. Event context is available through hotel.eventId.
model HotelManifestEntry {
  id         String    @id @default(cuid())
  attendeeId String
  hotelId    String
  roomNumber String?
  checkIn    DateTime?
  checkOut   DateTime?
  notes      String?

  attendee Attendee @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
  hotel    Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([hotelId, attendeeId])
  @@index([attendeeId])
  @@index([hotelId])
}

// Any ops-managed A→B transfer (bus, car, flight, or other)
model Movement {
  id                String       @id @default(cuid())
  eventId           String
  name              String       // e.g., "Bus 1 — Hotel to Airport"
  mode              MovementMode
  departureLocation String
  arrivalLocation   String
  departureTime     DateTime
  arrivalTime       DateTime?
  meetTime          DateTime?
  meetLocation      String?
  notes             String?

  event                   Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  movementManifestEntries MovementManifestEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
}

enum MovementMode {
  BUS
  CAR
  FLIGHT
  TRAIN
  WALK
  OTHER
}

// An attendee on a specific Movement, with real-time check-in
model MovementManifestEntry {
  id          String              @id @default(cuid())
  movementId  String
  attendeeId  String
  status      MovementEntryStatus @default(PENDING)
  checkedInAt DateTime?
  notes       String?

  movement Movement @relation(fields: [movementId], references: [id], onDelete: Cascade)
  attendee Attendee @relation(fields: [attendeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([movementId, attendeeId])
  @@index([movementId])
}

enum MovementEntryStatus {
  PENDING
  CHECKED_IN
}

enum FlightStatus {
  SCHEDULED
  ON_TIME
  DELAYED
  LANDED
  CANCELLED
}
